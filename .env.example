# ──────────────────────────────────────────────────────────────────────────────
# Phantom Adversarial — Environment Variables Template
# Copy this file to .env and populate with your credentials.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────────────────

PHANTOM_ENV=development                   # development | staging | production
PHANTOM_LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
PHANTOM_LOG_FORMAT=json                   # json | pretty
PHANTOM_OUTPUT_DIR=./results              # Default output directory for campaigns
PHANTOM_ARCHIVE_DIR=./archive             # QD archive persistence directory
PHANTOM_EVIDENCE_DIR=./evidence           # Chain-of-custody evidence storage

# ─── OpenAI ──────────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-...                     # Required for OpenAI models (GPT-4o, GPT-5.x)
OPENAI_ORG_ID=org-...                     # Optional: OpenAI organization ID
OPENAI_BASE_URL=https://api.openai.com/v1 # Override for OpenAI-compatible endpoints

# ─── Anthropic ───────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...              # Required for Claude models

# ─── Google ──────────────────────────────────────────────────────────────────

GOOGLE_API_KEY=AIza...                    # Required for Gemini models
GOOGLE_PROJECT_ID=                        # Optional: GCP project ID for Vertex AI
GOOGLE_LOCATION=us-central1               # Vertex AI region (if using Vertex)

# ─── Mistral ─────────────────────────────────────────────────────────────────

MISTRAL_API_KEY=                          # Required for Mistral models

# ─── DeepSeek ────────────────────────────────────────────────────────────────

DEEPSEEK_API_KEY=                         # Required for DeepSeek models
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ─── Ollama (local models) ───────────────────────────────────────────────────

OLLAMA_BASE_URL=http://localhost:11434    # Ollama local server URL
OLLAMA_TIMEOUT=300                        # Request timeout in seconds (large models are slow)

# ─── OpenRouter (multi-provider gateway) ─────────────────────────────────────

OPENROUTER_API_KEY=sk-or-...             # Required for OpenRouter access
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Evaluator Configuration ─────────────────────────────────────────────────

# Judge LLM for final evaluation (used in Mode 3 evaluator)
JUDGE_MODEL=openai:gpt-4o                 # Model used for judge-LLM evaluation
JUDGE_API_KEY=                            # Override API key for judge model (uses model provider key if empty)

# Embedding evaluator
EMBEDDING_MODEL=intfloat/e5-base-v2       # HuggingFace model for embedding-based evaluation
EMBEDDING_DEVICE=cpu                      # cpu | cuda | mps
EMBEDDING_BATCH_SIZE=64

# StrongREJECT evaluator
STRONGREJECT_THRESHOLD=0.70               # Score above which a response is classified as harmful

# ─── Promptfoo Integration ───────────────────────────────────────────────────

PROMPTFOO_CACHE_PATH=./.promptfoo/cache   # Promptfoo cache directory

# ─── Campaign Defaults ───────────────────────────────────────────────────────

PHANTOM_DEFAULT_CONCURRENCY=5             # Max concurrent requests per target
PHANTOM_DEFAULT_RATE_LIMIT=100            # Max requests per minute per target
PHANTOM_DEFAULT_TIMEOUT=60               # Request timeout in seconds
PHANTOM_DEFAULT_MAX_ITERATIONS=10000     # Max iterations for fuzz campaigns
PHANTOM_DEFAULT_ASR_THRESHOLD=0.70       # ASR threshold for flagging findings

# ─── QD Archive ──────────────────────────────────────────────────────────────

PHANTOM_ARCHIVE_ENABLED=true
PHANTOM_ARCHIVE_TYPE=map-elites           # map-elites | simple-dict
PHANTOM_ARCHIVE_CELLS_PER_DIM=10         # Grid resolution per behavioral descriptor dimension
PHANTOM_ARCHIVE_SAVE_INTERVAL=500        # Save archive to disk every N iterations

# ─── RL Mutation Selector ────────────────────────────────────────────────────

PHANTOM_RL_ENABLED=true
PHANTOM_RL_ALGORITHM=q-learning           # q-learning | epsilon-greedy
PHANTOM_RL_EPSILON=0.20                   # Exploration rate (0=greedy, 1=random)
PHANTOM_RL_LEARNING_RATE=0.10            # Q-table update learning rate
PHANTOM_RL_DISCOUNT_FACTOR=0.95          # Reward discount factor

# ─── Security & Evidence ─────────────────────────────────────────────────────

PHANTOM_ENCRYPT_EVIDENCE=true             # Encrypt evidence files at rest (AES-256)
PHANTOM_EVIDENCE_KEY=                     # AES-256 key (hex-encoded, 64 chars). Generate with: openssl rand -hex 32
PHANTOM_CHAIN_OF_CUSTODY=true            # Enable chain-of-custody logging
PHANTOM_OPERATOR_ID=                      # Identifier logged in chain-of-custody records

# ─── Reporting ───────────────────────────────────────────────────────────────

PHANTOM_REPORT_INCLUDE_PAYLOADS=true     # Include full prompts in reports
PHANTOM_REPORT_REDACT_RESPONSES=false    # Redact harmful response content in reports
PHANTOM_REPORT_WATERMARK=                # Organization name for report watermarking

# ─── Proxy / Network ─────────────────────────────────────────────────────────

# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# ─── Development Only ────────────────────────────────────────────────────────

# Only relevant when PHANTOM_ENV=development
PHANTOM_DRY_RUN=false                    # Generate prompts but don't send to models
PHANTOM_MOCK_RESPONSES=false             # Return mock responses (no API calls)
PHANTOM_DEBUG_TOKENIZER=false            # Log tokenization details for evasion testing
